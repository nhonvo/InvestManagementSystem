{
  "Aws": {
    "EndpointUrl": "http://localhost:5000",
    "SnsTopicArn": "arn:aws:sns:us-east-1:123456789012:inventory-events",
    "SqsQueueUrl": "http://localhost:5000/123456789012/event-queue"
  },
  "Database": {
    "DefaultConnection": "host=db;port=5432;Database=InventoryAlertDb;Username=postgres;Password=password"
  },
  "Finnhub": {
    "ApiBaseUrl": "https://finnhub.io/api/v1/",
    "ApiKey": "your_finnhub_api_key"
  },
  "Redis": {
    "Connection": "redis:6379"
  },
  "SqsPolling": {
    "UseNativeWorker": true,
    "QueueCapacity": 10
  }
}