{
  "_comment": "Copy this file to appsettings.Development.json and fill in real values. Never commit secrets.",
  "Database": {
    "DefaultConnection": "host=localhost;port=5432;Database=InventoryAlertDb;Username=postgres;Password=YOUR_DB_PASSWORD"
  },
  "Finnhub": {
    "ApiBaseUrl": "https://finnhub.io/api/v1/",
    "ApiKey": "YOUR_FINNHUB_API_KEY"
  },
  "MinuteSyncCurrentPrice": 10,
  "AWS": {
    "EndpointUrl": "http://localhost:5000",
    "SnsTopicArn": "arn:aws:sns:us-east-1:123456789012:inventory-events",
    "SqsQueueUrl": "http://localhost:5000/123456789012/event-queue"
  },
  "Telegram": {
    "BotToken": "YOUR_TELEGRAM_BOT_TOKEN",
    "ChatId": "YOUR_TELEGRAM_CHAT_ID"
  },
  "Logging": {
    },
  "Jwt": {
    "Key": "YOUR_SECURE_JWT_KEY",
    "Issuer": "InventoryAlert.Api",
    "Audience": "InventoryAlert.Web"
  },
  "Auth": {
    "Username": "admin",
    "Password": "YOUR_SECURE_PASSWORD"
  }
}

